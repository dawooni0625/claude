{
  "name": "kirbs-design-tokens",
  "version": "1.0.0",
  "description": "KIRBS 디자인 시스템 토큰 — W3C DTCG 포맷",
  "private": true,
  "scripts": {
    "build":       "style-dictionary build --config sd.config.js",
    "build:css":   "style-dictionary build --config sd.config.js --platform css",
    "build:scss":  "style-dictionary build --config sd.config.js --platform scss",
    "watch":       "nodemon --watch tokens/ --ext json --exec \"npm run build\""
  },
  "devDependencies": {
    "style-dictionary": "^4.3.0",
    "nodemon": "^3.1.0"
  }
}
